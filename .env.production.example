# LinuxONE Production Environment Configuration
# Copy this file to .env and update with actual values

# ============================================================================
# LLM Provider Configuration
# ============================================================================
LLM_PROVIDER=external

# External LLM (BOB API) - Primary for LinuxONE Production
BOB_API_KEY=your_bob_api_key_here
BOB_API_BASE_URL=https://api.bob.build/v1
BOB_MODEL=gpt-4o-mini

# Ollama (Local) - Fallback/Development (not used in production)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://raguser:secure_password_here@localhost:5432/linuxone_rag
POSTGRES_USER=raguser
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=linuxone_rag

# ============================================================================
# Embedding Configuration
# ============================================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ============================================================================
# Application Configuration
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=https://your-linuxone-domain.com

# ============================================================================
# RAG Configuration (Context-First Hybrid RAG optimized)
# ============================================================================
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K_RESULTS=5
MAX_CONTEXT_LENGTH=2000
MAX_CHUNKS_TO_LLM=8
MAX_CONTEXT_TOKENS=1200

# ============================================================================
# Retrieval Quality Settings
# ============================================================================
MIN_SIMILARITY_ABSOLUTE=0.4
SIMILARITY_RELATIVE_THRESHOLD=0.6
DIVERSITY_THRESHOLD=0.95
MIN_RELEVANCE_THRESHOLD=0.2
ENABLE_RERANKING=true
ENABLE_ADAPTIVE_FILTERING=true
ENABLE_DIVERSITY_FILTERING=true
RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ============================================================================
# LLM Generation Settings
# ============================================================================
LLM_MAX_TOKENS=2500
LLM_TEMPERATURE=0.2

# ============================================================================
# Feature Flags (LinuxONE Production)
# ============================================================================
# Set to false if AI dependencies are not installed on LinuxONE
ENABLE_LOCAL_EMBEDDINGS=true
ENABLE_LOCAL_RERANKING=true
ENABLE_PDF_PROCESSING=false

# ============================================================================
# Notes for LinuxONE Deployment
# ============================================================================
# 1. Install base dependencies: pip install -r backend/requirements-base.txt
# 2. Optionally install AI dependencies: pip install -r backend/requirements-ai.txt
# 3. If AI dependencies fail on s390x, set ENABLE_LOCAL_* flags to false
# 4. External LLM (BOB API) will handle generation regardless of local AI setup
# 5. Ensure PostgreSQL with pgvector extension is installed and running